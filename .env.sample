# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/twilight"

### runtime
PORT=3113
NODE_ENV=development
DEBUG_MODE=true
LOG_LEVEL=debug
PRISMA_QUERY_LOG=false

### urls
BASE_URL=http://localhost:3113
CLIENT_URL=http://localhost:3000

### auth
BCRYPT_SALT_ROUNDS=10
ACCESS_SECRET=change-me-access-secret
REFRESH_SECRET=change-me-refresh-secret
ACCESS_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d
JWT_ISSUER=
JWT_AUDIENCE=

### oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

### mail
EMAIL_FROM="Twilight <no-reply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

### uploads
FILE_UPLOAD_PATH=./public/uploads

### payment
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=

### optional cloud/cache placeholders
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

